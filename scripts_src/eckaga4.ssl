procedure do_setup
begin
	variable LVar0 := 0;
	variable LVar1 := 0;
	variable LVar2 := 0;
	debug_msg("eckaga4" + ": " + "do_setup" + "\n");
	if (not(local_var(7))) then begin
		debug_msg("eckaga4" + ": " + "not_defeated" + "\n");
		critter_add_trait(self_obj, 1, 6, 194);
		critter_add_trait(self_obj, 1, 5, 141);
		set_global_var(399, global_var(399) bwor 2);
		set_global_var(399, global_var(399) bwor 4);
		set_global_var(399, global_var(399) bwor 8);
		set_global_var(399, global_var(399) bwor 16);
		restock_amt := random(1, 1);
		if (obj_is_carrying_obj_pid(self_obj, 12) < restock_amt) then begin
			if (100 >= random(1, 100)) then begin
				if (obj_is_carrying_obj_pid(self_obj, 12) < restock_amt) then begin
					restock_obj := create_object_sid(12, 0, 0, -1);
					add_mult_objs_to_inven(self_obj, restock_obj, restock_amt - obj_is_carrying_obj_pid(self_obj, 12));
				end
				else begin
					if (obj_is_carrying_obj_pid(self_obj, 12) > restock_amt) then begin
						removed_qty := obj_is_carrying_obj_pid(self_obj, 12);
						if ((obj_is_carrying_obj_pid(self_obj, 12) - restock_amt) < removed_qty) then begin
							removed_qty := obj_is_carrying_obj_pid(self_obj, 12) - restock_amt;
						end
						if (removed_qty > 0) then begin
							restock_obj := obj_carrying_pid_obj(self_obj, 12);
