		add_obj_to_inven(LVar0, create_object_sid(280, 0, 0, -1));
		add_mult_objs_to_inven(LVar0, create_object_sid(41, 0, 0, -1), random(0, 30));
		wield_obj_critter(LVar0, obj_carrying_pid_obj(LVar0, 280));
		critter_add_trait(LVar0, 1, 6, 194);
		critter_add_trait(LVar0, 1, 5, 12);
		LVar1 := (has_trait(1, dude_obj, 10) + 3) % 6;
		LVar2 := tile_num_in_direction(tile_num(self_obj), LVar1, random(3, 4));
		critter_attempt_placement(LVar0, LVar2, 0);
		anim(LVar0, 1000, rotation_to_tile(tile_num(LVar0), tile_num(dude_obj)));
		if (global_var(399) bwand 64) then begin
			float_msg(dude_obj, message_str(834, 120), 3);
			set_local_var(4, 1);
			set_local_var(5, 2);
		end
		else begin
			add_timer_event(self_obj, 1, 1);
		end
	end
end

procedure map_enter_p_proc
begin
	if (not(metarule(22, 0))) then begin
		call do_setup();
	end
end

procedure combat_p_proc
begin
	if (has_trait(1, self_obj, 666)) then begin
		if (random(1, 100) <= 50) then begin
			if (critter_is_fleeing(self_obj)) then begin
				call NodeFleeing();
			end
			else begin
				call NodeFighting();
			end
		end
		if (get_critter_stat(self_obj, 35) <= (get_critter_stat(self_obj, 7) - 175)) then begin
			critter_set_flee_state(self_obj, 1);
		end
		if (not(obj_on_screen(self_obj)) or (tile_distance_objs(dude_obj, self_obj) > 15) and critter_is_fleeing(self_obj)) then begin
			float_msg(self_obj, message_str(834, 109), 2);
			set_global_var(399, global_var(399) bwor 64);
			debug_msg("eckaga4" + ": " + "set invisible" + "\n");
			set_obj_visibility(self_obj, 1);
		end
	end
end

procedure timed_event_p_proc
begin
	if (fixed_param == 1) then begin
		call doSequence();
	end
end

procedure Node998
begin
	set_local_var(5, 2);
	end_dialogue;
end

procedure Node999
begin
end

procedure NodeFleeing
begin
	float_msg(self_obj, message_str(834, random(108, 110)), 8);
end

procedure NodeFighting
begin
	variable LVar0 := 0;
	LVar0 := random(103, 107);
	if ((LVar0 == 103) and not(global_var(399) bwand 64)) then begin
		LVar0 := 104;
	end
	float_msg(self_obj, message_str(834, LVar0), 2);
end

procedure doSequence
begin
	anim(self_obj, 1000, rotation_to_tile(tile_num(self_obj), tile_num(dude_obj)));
	anim(dude_obj, 1000, rotation_to_tile(tile_num(dude_obj), tile_num(self_obj)));
	pending_dialog := 1;
end

